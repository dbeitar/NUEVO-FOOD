# ===============================================================
#  FRONTEND — VARIABLES DE ENTORNO (Vite)
#  Copia este archivo a `.env` (raíz) y completa con tus valores.
#  Todo lo expuesto al cliente DEBE empezar con VITE_.
#  NO versionar `.env`.
# ===============================================================

# URL base de la API del backend (incluye /api).
# En dev local (backend MVPFOOD):
#   PORT=3001 por defecto en backend/.env
#   Si el puerto 3001 está ocupado (otro proyecto), usa 3002:
VITE_API_BASE_URL=http://localhost:3002/api

# Marca pública por defecto cuando el usuario aún no pertenece a un gym
# con `brand_name` configurado. Se muestra en el navbar y como
# fallback en PDFs, etc.
VITE_BRAND_NAME=D28D Gimnasio Virtual

# Habilita el botón "Chef IA" (mock de receta) en la biblioteca de
# recetas. Por defecto OFF: el catálogo curado es el único origen.
# Solo activar para pruebas internas.
VITE_ENABLE_RECIPE_MOCK=false

# Registro comercial por pasos (servicio → programa → plan → moneda). false = registro legacy con código invite.
VITE_REGISTER_WIZARD_V2=true

# Food Plan embebido (modules/food_version_final) en /food-plan — modo por defecto
VITE_FOOD_LEGACY=false
VITE_FOOD_MODULE_URL=https://foodplan.tech
# Proxy Vite /food-api → API Food (prod o local)
# VITE_FOOD_API_PROXY=https://foodplan.tech

# Producción: FOOD_MODULE_URL en backend/.env (ver backend/.env.example)
# Módulo Entrenadores embebido (/training-module) — modo por defecto
VITE_TRAINING_LEGACY=false
# VITE_TRAINING_EXTERNAL=false
# VITE_TRAINING_MODULE_URL=http://localhost:5175
