# ===============================================================
#  FRONTEND — VARIABLES DE ENTORNO (Vite)
#  Copia este archivo a `.env` (raíz) y completa con tus valores.
#  Todo lo expuesto al cliente DEBE empezar con VITE_.
#  NO versionar `.env`.
# ===============================================================

# URL base de la API del backend (incluye /api).
# En dev local típico:
VITE_API_BASE_URL=http://localhost:3001/api

# Marca pública por defecto cuando el usuario aún no pertenece a un gym
# con `brand_name` configurado. Se muestra en el navbar y como
# fallback en PDFs, etc.
VITE_BRAND_NAME=D28D Gimnasio Virtual

# Habilita el botón "Chef IA" (mock de receta) en la biblioteca de
# recetas. Por defecto OFF: el catálogo curado es el único origen.
# Solo activar para pruebas internas.
VITE_ENABLE_RECIPE_MOCK=false
