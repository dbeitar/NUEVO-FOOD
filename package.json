{
  "name": "proyectofood-plan",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n front,back -c green,cyan \"npm run dev\" \"npm --prefix backend run dev\"",
    "autosave": "node scripts/autosave.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "test": "vitest run --passWithNoTests",
    "deploy:vercel": "npx vercel"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "0.575.0",
    "morgan": "^1.10.1",
    "pg": "^8.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@tailwindcss/postcss": "4.2.0",
    "@tailwindcss/vite": "4.2.0",
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "10.4.24",
    "concurrently": "9.1.2",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.0",
    "vercel": "^50.25.2",
    "vite": "7.3.1",
    "vitest": "^2.1.5"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": false
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react/prop-types": "off"
    }
  }
}
