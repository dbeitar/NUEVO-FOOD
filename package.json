{
  "name": "proyectofood-plan",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n front,back -c green,cyan \"npm run dev\" \"npm --prefix backend run dev\"",
    "autosave": "node scripts/autosave.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 10000",
    "doc:gen": "node scripts/md-to-docx.mjs",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "test": "vitest run --passWithNoTests",
    "seed:verify": "node scripts/seed_production_verify.cjs",
    "seed:invites": "node scripts/seed_invite_codes.cjs",
    "seed:pilot": "node scripts/reset_pilot_passwords.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "1.13.5",
    "jspdf": "^2.5.1",
    "lucide-react": "0.575.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@tailwindcss/postcss": "4.2.0",
    "@tailwindcss/vite": "4.2.0",
    "@vitejs/plugin-react": "5.1.4",
    "artillery": "^2.0.31",
    "autoprefixer": "10.4.24",
    "concurrently": "9.1.2",
    "docx": "^8.5.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "postcss": "8.5.6",
    "tailwindcss": "4.2.0",
    "vite": "7.3.1",
    "vitest": "^2.1.5"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": false
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "settings": {
      "react": {
        "version": "detect"
      }
    },
    "rules": {
      "react/prop-types": "off"
    }
  }
}
