# ===============================================================
#  BACKEND — VARIABLES DE ENTORNO
#  Copia este archivo a `backend/.env` y completa con tus valores.
#  NO versionar `backend/.env`.
# ===============================================================

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- CORS (lista separada por comas, sin espacios) ---
# Ej: http://localhost:5175,https://tu-marca.com
CORS_ORIGIN=http://localhost:5175

# --- Auth (OBLIGATORIO en cualquier modo) ---
# El servidor SE NIEGA A ARRANCAR si JWT_SECRET no está definido.
# Genera uno largo y aleatorio (>= 32 chars), p. ej.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Persistencia (default JSON = piloto/prod seguro hoy) ---
# false → TODO el dominio en backend/data/*.json (requiere disco persistente en prod).
# true  → SOLO login/registro en PostgreSQL; el resto SIGUE en JSON (NO usar en prod
#         hasta migración completa). Ver docs/manuales/04_TECNICO_Y_DESPLIEGUE.md.
USE_DB_AUTH=false
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foodplan
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# --- IA local (opcional, fallback determinístico si no está) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Endpoints de desarrollo (NUNCA habilitar en producción) ---
# Solo se montan si NODE_ENV != production Y ENABLE_DEV_ROUTES=true.
ENABLE_DEV_ROUTES=false

# --- Mocks ---
# Endpoint `/api/ai/generate-recipe` está deshabilitado por defecto
# (responde 404). Solo activar en pruebas internas.
ENABLE_RECIPE_MOCK=false

# --- Demo / cuentas core (opt-in) ---
# Si SEED_DEMO=true, al arrancar se sincronizan/crean las cuentas demo
# y el catálogo D28D (gym, programas, plantillas de clase).
# Sin SEED_DEMO=true el seed NO se ejecuta (recomendado en piloto/prod).
# En NODE_ENV=development sin override el seed sí corre por conveniencia.
SEED_DEMO=false
DEMO_USER_EMAIL=demo+20260302@foodplan.local
DEMO_PASSWORD=
CORE_PASSWORD=
CORE_ACCOUNT_EMAILS=admin@foodplan.local

# --- Módulo Food Plan (food_version_final / api/v1) — OBLIGATORIO para UI verde ---
FOOD_MODULE_URL=https://foodplan.tech/api/v1
FOOD_MODULE_PUBLIC_URL=https://foodplan.tech
# FOOD_SSO_SECRET=<opcional; default JWT_SECRET del shell>
# FOOD_SHELL_API_KEY=<clave server-to-server Food>
# FOOD_SSO_TTL_SEC=120
# SHELL_PUBLIC_URL=http://localhost:5175
# FOOD_EMBEDDED=true
# FOOD_LEGACY_ROUTES_OPEN=true
# SHELL_PUBLIC_URL=http://localhost:5175
# VITE_FOOD_LEGACY=false

# --- Módulo TRAINING (paridad Food; interno por defecto en shell) ---
# TRAINING_MODULE_URL=
# TRAINING_MODULE_PUBLIC_URL=
# TRAINING_SSO_SECRET=<opcional, default JWT_SECRET>
# TRAINING_SHELL_API_KEY=
# TRAINING_SSO_TTL_SEC=120
# TRAINING_LEGACY_ROUTES_OPEN=true
# TRAINING_EXTERNAL_MODE=false

# --- Fase 6: planes training en SQL además de DomainDocument ---
# TRAINING_PLANS_SQL=true

# ===============================================================
#  CREDENCIALES ZOOM (D28D)
#  Estas variables NO viajan al frontend. Solo se usan en backend
#  cuando se necesite arrancar/asociar una sesión Zoom.
#  Las contraseñas anteriores estaban versionadas y se consideran
#  COMPROMETIDAS: rotar antes de poner valor aquí.
# ===============================================================
D28D_ZOOM_EMAIL_VITAL=
D28D_ZOOM_PASSWORD_VITAL=

D28D_ZOOM_EMAIL_PANCITAS=
D28D_ZOOM_PASSWORD_PANCITAS=

D28D_ZOOM_EMAIL_VIRTUAL_1=
D28D_ZOOM_PASSWORD_VIRTUAL_1=

D28D_ZOOM_EMAIL_VIRTUAL_2=
D28D_ZOOM_PASSWORD_VIRTUAL_2=
