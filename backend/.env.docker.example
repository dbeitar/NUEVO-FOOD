# Copiar a backend/.env para desarrollo con Docker Compose
NODE_ENV=development
PORT=3001

JWT_SECRET=dev-only-change-in-production-min-32-chars-long-secret
JWT_EXPIRES_IN=7d

# PostgreSQL (docker compose)
DATABASE_URL=postgresql://mvpfood:mvpfood_dev_secret@localhost:5434/mvpfood?schema=public

USE_RELATIONAL_STORAGE=true
# Fase 6: planes de entrenamiento también en tabla training_plan_rows (dual-read con JSON)
TRAINING_PLANS_SQL=true
# FOOD_MODULE_URL=https://foodplan.tech/api/v1
# FOOD_MODULE_PUBLIC_URL=https://foodplan.tech
USE_JSON_FILES=false
USE_PG_STORAGE=true
USE_PRISMA=true
USE_DB_AUTH=false

CORS_ORIGIN=http://localhost:5175,http://127.0.0.1:5175

SEED_DEMO=false
ENABLE_DEV_ROUTES=true
D28D_INVITE_CODE=D28D,D28D-PILOTO,D28D-PILOTO-2026
