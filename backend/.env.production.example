# ===============================================================
#  PRODUCCIÓN — plantilla segura (copiar a backend/.env en el servidor)
#  NO versionar el .env real.
# ===============================================================

NODE_ENV=production
PORT=3001

# --- Auth (OBLIGATORIO) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Persistencia (PostgreSQL + Prisma — obligatorio en producción) ---
USE_PG_STORAGE=true
USE_PRISMA=true
USE_DB_AUTH=false
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- CORS (dominio exacto del frontend en HTTPS) ---
CORS_ORIGIN=https://tu-frontend.vercel.app

# --- PostgreSQL (alternativa a DATABASE_URL) ---
DB_CLIENT=pg
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# --- Códigos de registro público (D28D) ---
D28D_INVITE_CODE=D28D,D28D-PILOTO,D28D-PILOTO-2026

# --- Nunca en producción real ---
SEED_DEMO=false
ENABLE_DEV_ROUTES=false
ENABLE_RECIPE_MOCK=false

# --- Zoom (solo servidor) ---
D28D_ZOOM_EMAIL_VITAL=
D28D_ZOOM_PASSWORD_VITAL=
D28D_ZOOM_EMAIL_PANCITAS=
D28D_ZOOM_PASSWORD_PANCITAS=
D28D_ZOOM_EMAIL_VIRTUAL_1=
D28D_ZOOM_PASSWORD_VIRTUAL_1=
D28D_ZOOM_EMAIL_VIRTUAL_2=
D28D_ZOOM_PASSWORD_VIRTUAL_2=
